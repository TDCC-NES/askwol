@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# Only skos:Concept instances defined in the ontology's own namespace are
# flagged here: a concept scheme is subject-matter data, not schema, so it
# belongs in a separate resource. Named individuals (owl:NamedIndividual) are
# deliberately not flagged: many ontologies define a small, fixed set of
# individuals alongside their schema (e.g. OWL-Time's days of week and time
# units), which is a common, legitimate modeling pattern rather than
# accidental instance data left in a schema file.
<https://w3id.org/askwol/shapes/NonOntologyTermsShape>
    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            PREFIX owl: <http://www.w3.org/2002/07/owl#>
            PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
            SELECT DISTINCT ?this WHERE {
                ?this a skos:Concept .
                FILTER(isIRI(?this))
                ?ont a owl:Ontology .
                BIND(REPLACE(STR(?ont), "^(.*[/#])[^/#]*$", "$1") AS ?ontologyNs)
                FILTER(STRSTARTS(STR(?this), ?ontologyNs))
            }
        """ ;
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:name "ConceptInSchema" ;
        sh:severity sh:Warning ;
        sh:message "A skos:Concept defined in the ontology's own namespace. Concepts belong in a separate SKOS concept scheme, not mixed into the schema file." ;
        sh:select """
            PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
            SELECT $this WHERE {
                $this a skos:Concept .
            }
        """ ;
    ] .
