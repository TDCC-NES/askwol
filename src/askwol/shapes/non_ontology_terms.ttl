@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# A term in the ontology's own namespace is fine when at least one of its
# rdf:type values is a recognized schema construct (class, property,
# datatype, or the ontology header itself). Untyped terms are covered by the
# internal-terms check instead, and external terms are out of scope here, so
# the target requires at least one rdf:type and an owl:Ontology declaration.
<https://w3id.org/askwol/shapes/NonOntologyTermsShape>
    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            PREFIX owl: <http://www.w3.org/2002/07/owl#>
            SELECT DISTINCT ?this WHERE {
                ?this a ?anyType .
                FILTER(isIRI(?this))
                ?ont a owl:Ontology .
                BIND(REPLACE(STR(?ont), "^(.*[/#])[^/#]*$", "$1") AS ?ontologyNs)
                FILTER(STRSTARTS(STR(?this), ?ontologyNs))
            }
        """ ;
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:name "SchemaWhitelist" ;
        sh:severity sh:Warning ;
        sh:message "Not a recognized OWL/RDFS schema construct. Individuals, skos:Concept instances, and other instance data belong in a separate data resource or concept scheme." ;
        sh:select """
            PREFIX owl: <http://www.w3.org/2002/07/owl#>
            PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
            PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
            SELECT $this WHERE {
                FILTER NOT EXISTS {
                    $this a ?schemaType .
                    FILTER(?schemaType IN (
                        owl:Class, rdfs:Class, owl:ObjectProperty, owl:DatatypeProperty,
                        owl:AnnotationProperty, rdf:Property, owl:FunctionalProperty,
                        owl:InverseFunctionalProperty, owl:TransitiveProperty, owl:SymmetricProperty,
                        owl:AsymmetricProperty, owl:ReflexiveProperty, owl:IrreflexiveProperty,
                        rdfs:Datatype, owl:Ontology
                    ))
                }
            }
        """ ;
    ] .
