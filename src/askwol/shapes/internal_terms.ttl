@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# A term is a candidate for this check when it is referenced (used as a
# predicate or object) and its namespace matches where the ontology actually
# *defines* terms (a subject carrying a definitional rdf:type) - not the
# ontology IRI's own parent path, since a slash ontology IRI like
# https://host/dataset would otherwise claim the entire host, misclassifying
# unrelated IRIs such as an owl:versionIRI document. The ontology node itself
# and any owl:versionIRI target are never candidates.
<https://w3id.org/askwol/shapes/InternalTermsShape>
    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            PREFIX owl: <http://www.w3.org/2002/07/owl#>
            PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
            PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

            SELECT DISTINCT ?this WHERE {
                { ?s1 ?this ?o1 } UNION { ?s2 ?p2 ?this }
                FILTER(isIRI(?this))
                FILTER NOT EXISTS { ?this a owl:Ontology }
                FILTER NOT EXISTS { ?anyOnt owl:versionIRI ?this }
                FILTER EXISTS {
                    ?definedSubject a ?defType .
                    FILTER(?defType IN (
                        rdfs:Class, owl:Class, rdf:Property,
                        owl:ObjectProperty, owl:DatatypeProperty, owl:AnnotationProperty,
                        owl:FunctionalProperty, owl:InverseFunctionalProperty,
                        owl:TransitiveProperty, owl:SymmetricProperty,
                        owl:AsymmetricProperty, owl:ReflexiveProperty, owl:IrreflexiveProperty,
                        rdfs:Datatype, owl:NamedIndividual
                    ))
                    BIND(REPLACE(STR(?definedSubject), "^(.*[/#])[^/#]*$", "$1") AS ?definedNs)
                    FILTER(STRSTARTS(STR(?this), ?definedNs))
                }
            }
        """ ;
    ] ;

    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:name "InternalTermDefined" ;
        sh:message "Referenced in the ontology's own namespace but never defined. Usually a typo or a forgotten declaration." ;
        sh:select """
            SELECT $this WHERE {
                FILTER NOT EXISTS { $this ?anyPredicate ?anyObject }
            }
        """ ;
    ] .
